# ============================================================
# LearnPro LMS — Backend Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── Server ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
LOG_REQUESTS=false

# ── Database ────────────────────────────────────────────────
# Local:   postgresql://user:password@localhost:5432/lms_platform
# Railway: paste from Railway → Variables tab
DATABASE_URL=postgresql://user:password@localhost:5432/lms_platform

# ── JWT ─────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── OTP ─────────────────────────────────────────────────────
MOCK_OTP=false
MOCK_OTP_VALUE=123456

# ── Razorpay ────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS ────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com

# ── Email (optional) ────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password

# ── AI Integration ─────────────────────────────────────────────────────
# Add either or both — Claude is used first if both are present
# Get Claude key: https://console.anthropic.com
# Get OpenAI key: https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
